# ─────────────────────────────────────────────────────────────
# TradePilot AI — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.
# ─────────────────────────────────────────────────────────────

# Core
NODE_ENV=development
APP_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://tradepilot:tradepilot@localhost:5432/tradepilot?schema=public
DIRECT_URL=postgresql://tradepilot:tradepilot@localhost:5432/tradepilot?schema=public

# Redis (caching + rate limiting + queues)
REDIS_URL=redis://localhost:6379

# Auth (NextAuth v5). AUTH_SECRET is the canonical key in v5; NEXTAUTH_SECRET is
# read as a fallback. Set AUTH_SECRET in production (openssl rand -base64 32).
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
AUTH_SECRET=replace-with-openssl-rand-base64-32
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32
# Google OAuth + One Tap. OPTIONAL — leave blank to disable Google sign-in.
# AUTH_GOOGLE_ID is also used (server-side) as the One Tap client_id on /login.
# For One Tap to render, add your site origin (e.g. http://localhost:3000) to the
# OAuth client's "Authorized JavaScript origins" in Google Cloud Console.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Transactional email (verification + password reset). OPTIONAL in dev — when
# EMAIL_API_KEY is blank, links are printed to the server console instead.
EMAIL_API_KEY=
EMAIL_FROM=TradePilot AI <noreply@tradepilot.ai>

# Cron / internal job auth (Vercel Cron bearer token)
CRON_SECRET=replace-with-a-long-random-string

# Seed passwords (used by `prisma db:seed`; defaults exist but rotate for prod)
ADMIN_SEED_PASSWORD=ChangeMe!123
DEMO_SEED_PASSWORD=Demo!2345

# OpenAI (AI signal engine)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Market data layer (@tradepilot/marketdata)
# Provider selection: auto | binance | alphavantage | polygon
#   auto  → route by asset class (crypto→Binance, fx→Alpha Vantage, equity→Polygon)
# Admins can also override this at runtime in /admin/market-data (stored in DB).
MARKET_DATA_PROVIDER=auto
# Binance crypto market data needs NO key. Override the base URL only if needed.
BINANCE_BASE_URL=https://api.binance.com
# Alpha Vantage (forex). Free key: https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=
# Polygon.io (US stocks/options). Free key: https://polygon.io/dashboard/api-keys
POLYGON_API_KEY=

# Stripe (global billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ELITE=price_...

# Razorpay (India billing)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...

# Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHANNEL=

# WhatsApp alerts (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Monitoring
SENTRY_DSN=
LOG_LEVEL=info

# Rate limiting
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100
