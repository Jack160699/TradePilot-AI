{
  "name": "tradepilot-ai",
  "version": "1.0.0",
  "private": true,
  "description": "TradePilot AI — production-grade AI trading signals SaaS",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "turbo run db:generate",
    "db:migrate": "pnpm --filter @tradepilot/db db:migrate",
    "db:push": "pnpm --filter @tradepilot/db db:push",
    "db:seed": "pnpm --filter @tradepilot/db db:seed",
    "db:studio": "pnpm --filter @tradepilot/db db:studio",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  }
}
